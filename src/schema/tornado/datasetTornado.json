{
    "type": "object",
    "required": ["name", "description"],
    "properties": {
        "name": {
            "type": "string",
            "title": "Name"
        },
        "description": {
            "type": "string",
            "title": "Description"
        },
        "hazardDatasets": {
            "type": "array",
            "title": "Hazard Datasets",
            "items": {
                "type": "object",
                "required": ["demandType", "demandUnits", "shp", "shx", "dbf", "prj"],
                "properties": {
                    "demandType": {
                        "type": "string",
                        "title": "Demand Type",
                        "enumNames": ["Wind Speed"],
                        "enum": ["wind"],
                        "default": "wind"
                    },
                    "demandUnits": {
                        "type": "string",
                        "title": "Demand Unit",
                        "enumNames": ["Miles per Hour", "Metre per Second"],
                        "enum": ["mph", "mps"],
                        "default": "mph"
                    },
                    "shp": {
                        "type": "string",
                        "format": "data-url",
                        "title": "Tornado Shapefile (shp)"
                    },
                    "shx": {
                        "type": "string",
                        "format": "data-url",
                        "title": "Tornado Shapefile Index (shx)"
                    },
                    "dbf": {
                        "type": "string",
                        "format": "data-url",
                        "title": "Tornado Shapefile Attribute Table (dbf)"
                    },
                    "prj": {
                        "type": "string",
                        "format": "data-url",
                        "title": "Tornado Shapefile Projection (prj)"
                    }
                }
            }
        }
    }
}
