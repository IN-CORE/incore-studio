						"default": "wind"
					},
					"demandUnits": {
						"type": "string",
						"title": "Demand Unit",
						"enumNames": [
							"Miles per Hour",
							"Metre per Second"
						],
						"enum": ["mph", "mps"],
						"default": "mph"
					},
					"file": {
						"type": "string",
						"format": "data-url",
						"title": "Single file"
